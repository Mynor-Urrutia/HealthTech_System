# ============================================================
# HealthTech Solutions — Variables de Entorno
# Copiar a .env.dev / .env.staging / .env.prod y completar
# NUNCA commitear archivos .env con valores reales
# ============================================================

# ---- Django ----
DJANGO_ENV=dev                              # dev | staging | prod
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-secreta-larga

# ---- Oracle (DEV — 21c XE) ----
ORACLE_ENV=dev
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=XEPDB1
ORACLE_USER=healthtech_dev
ORACLE_PASSWORD=

# ---- Oracle (PROD — 19c RAC) — descomentar en prod ----
# ORACLE_ENV=prod
# ORACLE_OLTP_SERVICE=HEALTHTECH_OLTP         # Alias tnsnames.ora
# ORACLE_REPORTS_SERVICE=HEALTHTECH_REPORTS   # Alias tnsnames.ora
# ORACLE_USER=healthtech_app
# ORACLE_PASSWORD=

# ---- VPD / TDE ----
VPD_ENABLED=False           # True en staging y prod
TDE_ENABLED=False           # True solo en prod

# ---- AWS S3 (PACS) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_PACS_BUCKET=healthtech-pacs-dev
AWS_REGION=us-east-1

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Hosts permitidos ----
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Email ----
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
